{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Translate On Air",
  "version": "0.1.1",
  "identifier": "com.bachdx.translateonair",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "popup",
        "url": "index.html#/popup",
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true,
        "resizable": false,
        "width": 680,
        "height": 220,
        "focus": false
      },
      {
        "label": "settings",
        "url": "index.html#/settings",
        "visible": false,
        "title": "Settings",
        "width": 480,
        "height": 420,
        "center": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": "-"
    }
  }
}
